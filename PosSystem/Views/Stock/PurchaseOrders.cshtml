@using PosSystem.Controllers
@model System.Collections.Generic.List<StockController.PurchaseOrderRow>
@{
  Layout = "_Layout";
  var suppliers = ViewData["Suppliers"] as System.Collections.Generic.List<StockController.SupplierOption> ?? new();
  var openCreate = (ViewData["OpenCreate"] as bool?) == true;
}
<div class="space-y-6">
  @if (TempData["Success"] != null)
  {
    <div class="rounded-lg bg-green-50 text-green-700 px-4 py-3 text-sm">@TempData["Success"]</div>
  }
  @if (TempData["Error"] != null)
  {
    <div class="rounded-lg bg-red-50 text-red-700 px-4 py-3 text-sm">@TempData["Error"]</div>
  }
  <div class="flex justify-between items-center">
    <div><h2 class="text-xl font-bold text-gray-800">ใบขอสั่งซื้อ (Purchase Order)</h2></div>
    <a asp-action="PurchaseOrders" asp-route-openCreate="true" class="px-4 py-2 rounded-lg text-white text-sm inline-block" style="background:#2D6BE4">+ สร้าง PO</a>
  </div>
  <div class="bg-white rounded-xl shadow-sm overflow-hidden">
    <table class="w-full text-sm">
      <thead style="background:#F8FAFC">
        <tr class="text-left text-xs text-gray-500 uppercase">
          <th class="px-5 py-3">เลขที่ PO</th>
          <th class="px-5 py-3">ผู้ขาย</th>
          <th class="px-5 py-3">วันที่</th>
          <th class="px-5 py-3 text-right">มูลค่า</th>
          <th class="px-5 py-3">สถานะ</th>
        </tr>
      </thead>
      <tbody>
        @if (Model != null && Model.Count > 0)
        {
          @foreach (var po in Model)
          {
            <tr class="border-t hover:bg-gray-50">
              <td class="px-5 py-3 font-medium text-gray-800">@po.PoNumber</td>
              <td class="px-5 py-3 text-gray-600">@po.SupplierName</td>
              <td class="px-5 py-3 text-gray-600">@po.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
              <td class="px-5 py-3 text-right">฿@po.TotalAmount.ToString("N2")</td>
              <td class="px-5 py-3">
                <span class="px-2 py-1 text-xs rounded-full bg-blue-100 text-blue-700">@po.Status</span>
              </td>
            </tr>
          }
        }
        else
        {
          <tr><td colspan="5" class="px-5 py-12 text-center text-gray-400">
            <i data-lucide="file-text" class="w-10 h-10 mx-auto mb-2 opacity-30"></i>
            <p>ยังไม่มีใบสั่งซื้อ</p>
          </td></tr>
        }
      </tbody>
    </table>
  </div>
</div>

<div id="create-po-modal" class="@(openCreate ? "" : "hidden") fixed inset-0 bg-black/40 z-40">
  <div class="max-w-lg w-full bg-white rounded-xl shadow-xl p-5 mx-auto mt-20">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-semibold text-gray-800">สร้างใบขอสั่งซื้อ</h3>
      <a asp-action="PurchaseOrders" class="text-gray-400">✕</a>
    </div>
    <form method="post" asp-action="CreatePurchaseOrder" class="space-y-3">
      <select name="SupplierId" class="w-full px-3 py-2 border rounded-lg text-sm">
        <option value="">ไม่ระบุผู้ขาย</option>
        @foreach (var supplier in suppliers)
        {
          <option value="@supplier.Id">@supplier.Name</option>
        }
      </select>
      <textarea name="Note" placeholder="หมายเหตุ (ถ้ามี)" class="w-full px-3 py-2 border rounded-lg text-sm"></textarea>
      <div class="flex justify-end gap-2 pt-2">
        <a asp-action="PurchaseOrders" class="px-4 py-2 border rounded-lg text-sm inline-block">ยกเลิก</a>
        <button type="submit" class="px-4 py-2 rounded-lg text-white text-sm" style="background:#2D6BE4">สร้าง PO</button>
      </div>
    </form>
  </div>
</div>
