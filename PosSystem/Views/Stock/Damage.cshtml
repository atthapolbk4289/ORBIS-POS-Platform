@{ Layout = "_Layout"; }
<div class="space-y-6">
  <div class="flex justify-between items-center">
    <div><h2 class="text-xl font-bold text-gray-800">แจ้งทำลายสินค้า</h2></div>
    <button class="px-4 py-2 rounded-lg text-white text-sm bg-red-600">+ แจ้งทำลาย</button>
  </div>
  <div class="bg-white rounded-xl shadow-sm overflow-hidden">
    <table class="w-full text-sm">
      <thead style="background:#F8FAFC">
        <tr class="text-left text-xs text-gray-500 uppercase">
          <th class="px-5 py-3">เลขที่</th>
          <th class="px-5 py-3">สินค้า</th>
          <th class="px-5 py-3 text-right">จำนวน</th>
          <th class="px-5 py-3">สาเหตุ</th>
          <th class="px-5 py-3">อนุมัติโดย</th>
          <th class="px-5 py-3">วันที่</th>
        </tr>
      </thead>
      <tbody>
        <tr><td colspan="6" class="px-5 py-12 text-center text-gray-400">
          <i data-lucide="trash-2" class="w-10 h-10 mx-auto mb-2 opacity-30"></i>
          <p>ยังไม่มีรายการทำลายสินค้า</p>
        </td></tr>
      </tbody>
    </table>
  </div>
</div>
