@using PosSystem.Controllers
@model System.Collections.Generic.List<BranchesController.BranchRow>
@{ Layout = "_Layout"; }
<div class="space-y-6">
  @{
    var openCreate = (ViewData["OpenCreate"] as bool?) == true;
  }
  @if (TempData["Success"] != null)
  {
    <div class="rounded-lg bg-green-50 text-green-700 px-4 py-3 text-sm">@TempData["Success"]</div>
  }
  @if (TempData["Error"] != null)
  {
    <div class="rounded-lg bg-red-50 text-red-700 px-4 py-3 text-sm">@TempData["Error"]</div>
  }
  <div class="flex justify-between items-center">
    <div>
      <h2 class="text-xl font-bold text-gray-800">จัดการสาขา</h2>
      <p class="text-sm text-gray-500 mt-1">ดูและแก้ไขข้อมูลสาขาทั้งหมดในระบบ</p>
    </div>
    <a asp-action="Index" asp-route-openCreate="true" class="px-4 py-2 rounded-lg text-white text-sm font-medium inline-block" style="background:#2D6BE4">+ เพิ่มสาขา</a>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
    @if (Model != null && Model.Count > 0)
    {
      @foreach (var b in Model)
      {
        <div class="bg-white rounded-xl p-5 shadow-sm border hover:border-blue-400 transition-all">
          <div class="flex items-start justify-between mb-3">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background:#EEF4FF">
              <i data-lucide="building" class="w-5 h-5" style="color:#2D6BE4"></i>
            </div>
            <span class="text-xs px-2 py-1 rounded-full font-medium @(b.IsActive ? "bg-green-100 text-green-700" : "bg-gray-100 text-gray-500")">
              @(b.IsActive ? "เปิดใช้งาน" : "ปิดใช้งาน")
            </span>
          </div>
          <h3 class="font-semibold text-gray-800">@b.Name</h3>
          @if (!string.IsNullOrEmpty(b.TaxId))
          {
            <p class="text-xs text-gray-400 mt-1">เลขภาษี: @b.TaxId</p>
          }
          @if (!string.IsNullOrEmpty(b.Phone))
          {
            <p class="text-sm text-gray-600 mt-2 flex items-center gap-1">
              <i data-lucide="phone" class="w-3 h-3"></i> @b.Phone
            </p>
          }
          @if (!string.IsNullOrEmpty(b.Address))
          {
            <p class="text-xs text-gray-400 mt-1 line-clamp-2">@b.Address</p>
          }
          <div class="flex gap-2 mt-4">
            <button class="flex-1 py-1.5 border rounded-lg text-sm text-blue-600 hover:bg-blue-50">แก้ไข</button>
            <form asp-action="Delete" method="post" class="inline" onsubmit="return confirm('ปิดการใช้งานสาขานี้?')">
              <input type="hidden" name="id" value="@b.Id" />
              <button type="submit" class="px-3 py-1.5 border rounded-lg text-sm text-red-500 hover:bg-red-50">
                <i data-lucide="trash-2" class="w-4 h-4"></i>
              </button>
            </form>
          </div>
        </div>
      }
    }
    else
    {
      <div class="col-span-3 bg-white rounded-xl p-12 shadow-sm text-center text-gray-400">
        <i data-lucide="building" class="w-12 h-12 mx-auto mb-3 opacity-30"></i>
        <p>ยังไม่มีข้อมูลสาขา</p>
      </div>
    }
  </div>
</div>

<div id="create-branch-modal" class="@(openCreate ? "" : "hidden") fixed inset-0 bg-black/40 z-40">
  <div class="max-w-lg w-full bg-white rounded-xl shadow-xl p-5 mx-auto mt-20">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-semibold text-gray-800">เพิ่มสาขาใหม่</h3>
      <a asp-action="Index" class="text-gray-400">✕</a>
    </div>
    <form method="post" asp-action="Create" class="space-y-3">
      <input name="Name" required placeholder="ชื่อสาขา" class="w-full px-3 py-2 border rounded-lg text-sm" />
      <input name="Phone" placeholder="เบอร์โทร" class="w-full px-3 py-2 border rounded-lg text-sm" />
      <input name="TaxId" placeholder="เลขประจำตัวผู้เสียภาษี" class="w-full px-3 py-2 border rounded-lg text-sm" />
      <textarea name="Address" placeholder="ที่อยู่สาขา" class="w-full px-3 py-2 border rounded-lg text-sm"></textarea>
      <label class="flex items-center gap-2 text-sm text-gray-700">
        <input type="checkbox" name="IsActive" checked value="true" />
        เปิดใช้งานสาขาทันที
      </label>
      <div class="flex justify-end gap-2 pt-2">
        <a asp-action="Index" class="px-4 py-2 border rounded-lg text-sm inline-block">ยกเลิก</a>
        <button type="submit" class="px-4 py-2 rounded-lg text-white text-sm" style="background:#2D6BE4">บันทึก</button>
      </div>
    </form>
  </div>
</div>
