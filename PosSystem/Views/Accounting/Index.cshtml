@{ Layout = "_Layout"; }
<div class="space-y-6">
  <div class="flex justify-between items-center">
    <div>
      <h2 class="text-xl font-bold text-gray-800">บัญชี</h2>
      <p class="text-sm text-gray-500 mt-1">ภาพรวมการเงินและบัญชีประจำวัน</p>
    </div>
    <button class="px-4 py-2 rounded-lg text-white text-sm font-medium" style="background:#2D6BE4">
      + บันทึกรายการ
    </button>
  </div>

  <!-- Summary Cards -->
  <div class="grid grid-cols-3 gap-5">
    <div class="bg-white rounded-xl p-5 shadow-sm">
      <div class="flex items-center justify-between mb-3">
        <p class="text-sm text-gray-500">รายรับวันนี้</p>
        <div class="w-9 h-9 rounded-lg flex items-center justify-center" style="background:#EEF4FF">
          <i data-lucide="trending-up" class="w-5 h-5" style="color:#2D6BE4"></i>
        </div>
      </div>
      <p class="text-2xl font-bold text-gray-800">฿0.00</p>
    </div>
    <div class="bg-white rounded-xl p-5 shadow-sm">
      <div class="flex items-center justify-between mb-3">
        <p class="text-sm text-gray-500">รายจ่ายวันนี้</p>
        <div class="w-9 h-9 rounded-lg flex items-center justify-center" style="background:#FFF1F1">
          <i data-lucide="trending-down" class="w-5 h-5 text-red-500"></i>
        </div>
      </div>
      <p class="text-2xl font-bold text-gray-800">฿0.00</p>
    </div>
    <div class="bg-white rounded-xl p-5 shadow-sm">
      <div class="flex items-center justify-between mb-3">
        <p class="text-sm text-gray-500">กำไรสุทธิ</p>
        <div class="w-9 h-9 rounded-lg flex items-center justify-center" style="background:#F0FDF4">
          <i data-lucide="dollar-sign" class="w-5 h-5 text-green-600"></i>
        </div>
      </div>
      <p class="text-2xl font-bold text-green-600">฿0.00</p>
    </div>
  </div>

  <!-- Tabs -->
  <div class="bg-white rounded-xl shadow-sm overflow-hidden">
    <div class="flex border-b text-sm font-medium">
      <button class="px-6 py-3 text-blue-600 border-b-2 border-blue-600">รายรับ</button>
      <button class="px-6 py-3 text-gray-500 hover:text-gray-700">รายจ่าย</button>
      <button class="px-6 py-3 text-gray-500 hover:text-gray-700">สมุดรายวัน</button>
    </div>
    <div class="p-12 text-center text-gray-400">
      <i data-lucide="book-open" class="w-10 h-10 mx-auto mb-2 opacity-30"></i>
      <p>ยังไม่มีรายการบัญชี</p>
    </div>
  </div>
</div>
