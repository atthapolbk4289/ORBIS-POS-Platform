@model PosSystem.Controllers.ProfileViewModel
@{ Layout = "_Layout"; }

@if (TempData["Success"] != null)
{
  <div class="mb-5 flex items-center gap-3 bg-green-50 border border-green-200 text-green-700 px-5 py-3 rounded-xl text-sm">
    <i data-lucide="check-circle" class="w-5 h-5 flex-shrink-0"></i>
    <span>@TempData["Success"]</span>
  </div>
}
@if (TempData["Error"] != null)
{
  <div class="mb-5 flex items-center gap-3 bg-red-50 border border-red-200 text-red-700 px-5 py-3 rounded-xl text-sm">
    <i data-lucide="alert-circle" class="w-5 h-5 flex-shrink-0"></i>
    <span>@TempData["Error"]</span>
  </div>
}

<div class="max-w-3xl mx-auto space-y-6">

  <!-- Profile Card -->
  <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
    <!-- Header Banner -->
    <div class="h-24" style="background:linear-gradient(135deg,#1B3A6B,#2D6BE4)"></div>
    <div class="px-8 pb-6 -mt-10">
      <!-- Avatar -->
      <div class="flex items-end gap-5 mb-5">
        <div class="w-20 h-20 rounded-2xl flex items-center justify-center text-white text-3xl font-bold shadow-lg border-4 border-white"
             style="background:#2D6BE4">
          @(Model?.FullName?.Substring(0,1).ToUpper() ?? "U")
        </div>
        <div class="pb-1">
          <h2 class="text-xl font-bold text-gray-800">@Model?.FullName</h2>
          <span class="text-xs px-3 py-1 rounded-full font-medium bg-blue-100 text-blue-700">
            @(Model?.Role switch {
              "IT_ADMIN"     => "ผู้ดูแลระบบ",
              "MANAGER"      => "ผู้จัดการ",
              "CASHIER"      => "แคชเชียร์",
              "STOCK_KEEPER" => "คลังสินค้า",
              _              => Model?.Role ?? ""
            })
          </span>
        </div>
      </div>

      <!-- Info Grid -->
      <div class="grid grid-cols-2 gap-4 text-sm">
        <div class="bg-gray-50 rounded-xl p-4">
          <p class="text-xs text-gray-400 mb-1">ชื่อผู้ใช้</p>
          <p class="font-semibold text-gray-700">@Model?.Username</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-4">
          <p class="text-xs text-gray-400 mb-1">อีเมล</p>
          <p class="font-semibold text-gray-700">@(Model?.Email ?? "-")</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-4">
          <p class="text-xs text-gray-400 mb-1">เบอร์โทร</p>
          <p class="font-semibold text-gray-700">@(Model?.Phone ?? "-")</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-4">
          <p class="text-xs text-gray-400 mb-1">เข้าสู่ระบบล่าสุด</p>
          <p class="font-semibold text-gray-700">
            @(Model?.LastLoginAt?.ToString("dd/MM/yyyy HH:mm") ?? "ยังไม่เคยล็อกอิน")
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Change Password Card -->
  <div class="bg-white rounded-2xl shadow-sm p-6">
    <h3 class="font-semibold text-gray-800 mb-5 flex items-center gap-2">
      <i data-lucide="lock" class="w-5 h-5 text-blue-600"></i>
      เปลี่ยนรหัสผ่าน
    </h3>
    <form asp-action="ChangePassword" method="post" class="space-y-4">
      @Html.AntiForgeryToken()
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">รหัสผ่านปัจจุบัน</label>
        <input name="currentPassword" type="password"
               class="w-full px-4 py-2.5 border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
               placeholder="กรอกรหัสผ่านปัจจุบัน" />
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">รหัสผ่านใหม่</label>
          <input name="newPassword" type="password"
                 class="w-full px-4 py-2.5 border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                 placeholder="อย่างน้อย 6 ตัวอักษร" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">ยืนยันรหัสผ่านใหม่</label>
          <input name="confirmPassword" type="password"
                 class="w-full px-4 py-2.5 border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                 placeholder="พิมพ์รหัสผ่านใหม่อีกครั้ง" />
        </div>
      </div>
      <div class="flex justify-end">
        <button type="submit"
                class="px-6 py-2.5 rounded-xl text-white font-medium text-sm transition-all hover:opacity-90"
                style="background:#2D6BE4">
          บันทึกรหัสผ่านใหม่
        </button>
      </div>
    </form>
  </div>

</div>
