@model PosSystem.Models.ViewModels.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>POS System — เข้าสู่ระบบ</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>body { font-family: 'Noto Sans Thai', sans-serif; }</style>
</head>
<body class="h-screen flex bg-gray-100">
  <!-- Left Panel — Navy -->
  <div class="hidden md:flex w-2/5 flex-col items-center justify-center" style="background:#1B3A6B">
    <div class="text-white text-center p-8">
      <div class="text-6xl font-bold mb-4">ORBIS POS</div>
      <h1 class="text-3xl font-semibold mb-2">ระบบ POS</h1>
      <p class="text-blue-200 text-sm">จัดการร้านค้าและร้านอาหารครบวงจร</p>
      <div class="mt-8 grid grid-cols-2 gap-4 text-center text-xs text-blue-300">
        <div>📊 Dashboard</div><div>🛒 POS ขาย</div>
        <div>📦 สต็อกสินค้า</div><div>📋 ใบกำกับภาษี</div>
      </div>
    </div>
  </div>
  
  <!-- Right Panel — White -->
  <div class="flex-1 flex items-center justify-center p-8">
    <div class="w-full max-w-md">
      <h2 class="text-2xl font-bold text-gray-800 mb-2">เข้าสู่ระบบ</h2>
      <p class="text-gray-500 mb-8 text-sm">กรุณาใส่ข้อมูลเพื่อเข้าใช้งานระบบ</p>
      
      @if (!ViewData.ModelState.IsValid) {
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm">
          @Html.ValidationSummary(false)
        </div>
      }
      
      <form asp-action="Login" method="post">
        @Html.AntiForgeryToken()
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1">ชื่อผู้ใช้</label>
          <div class="relative">
            <span class="absolute left-3 top-3 text-gray-400">👤</span>
            <input asp-for="Username" class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="กรอกชื่อผู้ใช้" />
          </div>
        </div>
        <div class="mb-6">
          <label class="block text-sm font-medium text-gray-700 mb-1">รหัสผ่าน</label>
          <div class="relative">
            <span class="absolute left-3 top-3 text-gray-400">🔒</span>
            <input asp-for="Password" type="password" id="pwdInput" class="w-full pl-10 pr-10 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="กรอกรหัสผ่าน" />
            <button type="button" onclick="togglePwd()" class="absolute right-3 top-3 text-gray-400 hover:text-gray-600">👁</button>
          </div>
        </div>
        <button type="submit" class="w-full py-3 rounded-lg text-white font-semibold text-base transition-all"
                style="background:#1B3A6B" onmouseover="this.style.background='#2D6BE4'" onmouseout="this.style.background='#1B3A6B'">
          เข้าสู่ระบบ
        </button>
      </form>
      <p class="text-center text-xs text-gray-400 mt-8">POS System v1.0 — © 2026</p>
    </div>
  </div>
</body>
<script>function togglePwd() { var x=document.getElementById('pwdInput'); x.type=x.type==='password'?'text':'password'; }</script>
</html>
