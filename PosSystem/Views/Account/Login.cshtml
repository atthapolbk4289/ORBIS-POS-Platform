<!DOCTYPE html>
<html>
<head>
    <title>POS System — เข้าสู่ระบบ</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>body { font-family: 'Noto Sans Thai', sans-serif; }</style>
</head>
<body class="h-screen flex bg-white">
  <!-- Left Panel — Clean White with Blue accents -->
  <div class="hidden lg:flex w-1/2 flex-col items-center justify-center bg-slate-50 border-r border-slate-100 relative overflow-hidden">
    <!-- Abstract Background Decor -->
    <div class="absolute top-0 right-0 -mt-20 -mr-20 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-50"></div>
    <div class="absolute bottom-0 left-0 -mb-20 -ml-20 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-50"></div>

    <div class="z-10 text-center p-12">
      <div class="flex items-center justify-center mb-6">
        <div class="w-20 h-20 bg-blue-600 rounded-2xl flex items-center justify-center text-white shadow-2xl shadow-blue-200">
           <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.1 6.27a2 2 0 0 0-1.1 1.83V19a2 2 0 0 0 2 2h18a2 2 0 0 0 2-2V8.1a2 2 0 0 0-1.1-1.83l-9.07-4.09z"/><path d="m2.1 7.44 9.9 4.48 9.9-4.48"/><path d="M12 11.92V21"/></svg>
        </div>
      </div>
      <div class="text-4xl font-black text-slate-800 mb-4 tracking-tight">ORBIS POS</div>
      <h1 class="text-xl font-medium text-slate-600 mb-8">ระบบจัดการร้านค้าอัจฉริยะ</h1>
      
      <div class="grid grid-cols-2 gap-4">
        <div class="bg-white p-4 rounded-2xl shadow-sm border border-slate-100 text-slate-600 text-sm font-medium">📊 แดชบอร์ดอัจฉริยะ</div>
        <div class="bg-white p-4 rounded-2xl shadow-sm border border-slate-100 text-slate-600 text-sm font-medium">🛒 ระบบขาย POS</div>
        <div class="bg-white p-4 rounded-2xl shadow-sm border border-slate-100 text-slate-600 text-sm font-medium">📦 คลังสินค้าแม่นยำ</div>
        <div class="bg-white p-4 rounded-2xl shadow-sm border border-slate-100 text-slate-600 text-sm font-medium">📋 รายงานภาษีครบถ้วน</div>
      </div>
    </div>
  </div>
  
  <!-- Right Panel — Login Form -->
  <div class="flex-1 flex items-center justify-center p-8 bg-white">
    <div class="w-full max-w-sm">
      <div class="lg:hidden flex items-center justify-center mb-8">
         <div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center text-white shadow-xl shadow-blue-200">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.1 6.27a2 2 0 0 0-1.1 1.83V19a2 2 0 0 0 2 2h18a2 2 0 0 0 2-2V8.1a2 2 0 0 0-1.1-1.83l-9.07-4.09z"/><path d="m2.1 7.44 9.9 4.48 9.9-4.48"/><path d="M12 11.92V21"/></svg>
         </div>
         <span class="ml-3 text-xl font-bold text-slate-800">ORBIS POS</span>
      </div>

      <div class="mb-10">
        <h2 class="text-3xl font-bold text-slate-800 mb-2">เข้าสู่ระบบ</h2>
        <p class="text-slate-400 font-medium">ลงชื่อเข้าใช้งานเพื่อเริ่มจัดการธุรกิจของคุณ</p>
      </div>
      
      @if (!ViewData.ModelState.IsValid) {
        <div class="bg-rose-50 border border-rose-100 text-rose-600 px-4 py-3 rounded-2xl mb-6 text-sm font-medium">
          @Html.ValidationSummary(false)
        </div>
      }
      
      <form asp-action="Login" method="post" class="space-y-5">
        @Html.AntiForgeryToken()
        <div>
          <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2 ml-1">ชื่อผู้ใช้งาน</label>
          <div class="relative group">
            <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-blue-500 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <input asp-for="Username" required class="w-full pl-12 pr-4 py-3.5 bg-slate-50 border border-slate-100 rounded-2xl focus:outline-none focus:ring-4 focus:ring-blue-100 focus:bg-white focus:border-blue-500 transition-all text-slate-700" placeholder="กรอก Username ของคุณ" />
          </div>
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2 ml-1">รหัสผ่าน</label>
          <div class="relative group">
            <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-blue-500 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <input asp-for="Password" type="password" id="pwdInput" required class="w-full pl-12 pr-12 py-3.5 bg-slate-50 border border-slate-100 rounded-2xl focus:outline-none focus:ring-4 focus:ring-blue-100 focus:bg-white focus:border-blue-500 transition-all text-slate-700" placeholder="กรอกรหัสผ่าน" />
            <button type="button" onclick="togglePwd()" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 transition-colors">
               <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
        </div>
        
        <div class="pt-4">
          <button type="submit" class="w-full py-4 rounded-2xl bg-blue-600 text-white font-bold text-lg shadow-xl shadow-blue-100 hover:bg-blue-700 hover:shadow-blue-200 active:scale-[0.98] transition-all">
            เข้าสู่ระบบ
          </button>
        </div>
      </form>
      
      <div class="mt-12 text-center">
        <p class="text-xs text-slate-400 font-medium">POS System v1.0 — © 2026 ORBIS Group</p>
      </div>
    </div>
  </div>
</body>
<script>
  function togglePwd() { 
    var x = document.getElementById('pwdInput'); 
    x.type = x.type === 'password' ? 'text' : 'password'; 
  }
</script>
</html>

