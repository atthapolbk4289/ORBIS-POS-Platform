@model System.Collections.Generic.List<PosSystem.Controllers.ProductsController.CategoryRow>
@{ Layout = "_Layout"; }

<div class="space-y-6">
    <div class="flex justify-between items-center">
        <div>
            <h2 class="text-xl font-bold text-gray-800">จัดการหมวดหมู่สินค้า</h2>
            <p class="text-sm text-gray-500 mt-1">ตั้งค่าหมวดหมู่เพื่อใช้แยกประเภทสินค้าในหน้า POS</p>
        </div>
        <button onclick="document.getElementById('create-cat-modal').classList.remove('hidden')" 
                class="px-4 py-2 rounded-lg text-white text-sm font-medium transition-all" style="background:#2D6BE4">
            + เพิ่มหมวดหมู่
        </button>
    </div>

    @if (TempData["Success"] != null) {
        <div class="rounded-lg bg-green-50 text-green-700 px-4 py-3 text-sm">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null) {
        <div class="rounded-lg bg-red-50 text-red-700 px-4 py-3 text-sm">@TempData["Error"]</div>
    }

    <div class="bg-white rounded-xl shadow-sm overflow-hidden">
        <table class="w-full text-sm">
            <thead style="background:#F8FAFC">
                <tr class="text-left text-xs text-gray-500 uppercase font-semibold">
                    <th class="px-5 py-3">ลำดับ</th>
                    <th class="px-5 py-3">ชื่อหมวดหมู่</th>
                    <th class="px-5 py-3">สถานะ</th>
                    <th class="px-5 py-3 text-right">เครื่องมือ</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0) {
                    @foreach (var c in Model) {
                        <tr class="border-t hover:bg-gray-50">
                            <td class="px-5 py-3 text-gray-500">@c.DisplayOrder</td>
                            <td class="px-5 py-3 font-medium text-gray-800">@c.Name</td>
                            <td class="px-5 py-3">
                                <span class="px-2 py-1 text-xs rounded-full @(c.IsActive ? "bg-green-100 text-green-700" : "bg-gray-100 text-gray-500")">
                                    @(c.IsActive ? "เปิดใช้งาน" : "ปิดใช้งาน")
                                </span>
                            </td>
                            <td class="px-5 py-3 text-right space-x-2">
                                <form asp-action="DeleteCategory" method="post" class="inline" onsubmit="return confirm('ยืนยันการลบ?')">
                                    <input type="hidden" name="id" value="@c.Id" />
                                    <button type="submit" class="text-red-400 hover:text-red-600 transition-colors">
                                        <i data-lucide="trash-2" class="w-4 h-4"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                } else {
                    <tr>
                        <td colspan="4" class="px-5 py-12 text-center text-gray-400">
                            <i data-lucide="layers" class="w-10 h-10 mx-auto mb-2 opacity-30"></i>
                            <p>ยังไม่มีข้อมูลหมวดหมู่</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div id="create-cat-modal" class="hidden fixed inset-0 bg-black/40 z-50 flex items-center justify-center">
    <div class="bg-white rounded-xl shadow-xl p-6 w-full max-w-md">
        <div class="flex justify-between items-center mb-4">
            <h3 class="text-lg font-bold text-gray-800">เพิ่มหมวดหมู่ใหม่</h3>
            <button onclick="document.getElementById('create-cat-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600">✕</button>
        </div>
        <form asp-action="CreateCategory" method="post" class="space-y-4">
            <div>
                <label class="block text-xs text-gray-500 mb-1">ชื่อหมวดหมู่</label>
                <input name="name" required class="w-full px-3 py-2 border rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none" placeholder="เช่น เครื่องดื่ม, ของหวาน" />
            </div>
            <div>
                <label class="block text-xs text-gray-500 mb-1">ลำดับการแสดงผล</label>
                <input name="displayOrder" type="number" value="0" class="w-full px-3 py-2 border rounded-lg text-sm outline-none" />
            </div>
            <div class="flex justify-end gap-2 pt-2">
                <button type="button" onclick="document.getElementById('create-cat-modal').classList.add('hidden')" class="px-4 py-2 text-sm text-gray-600 hover:bg-gray-100 rounded-lg transition-all">ยกเลิก</button>
                <button type="submit" class="px-4 py-2 text-sm text-white rounded-lg font-medium transition-all" style="background:#2D6BE4">บันทึกข้อมูล</button>
            </div>
        </form>
    </div>
</div>
