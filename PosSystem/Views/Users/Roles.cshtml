@{ Layout = "_Layout"; }
<div class="space-y-6">
  <div><h2 class="text-xl font-bold text-gray-800">กำหนดสิทธิ์</h2></div>
  <div class="bg-white rounded-xl shadow-sm p-6">
    <div class="grid grid-cols-2 gap-6">
      @foreach (var role in new[] { ("IT_ADMIN","ผู้ดูแลระบบ","bg-purple-100 text-purple-700"), ("MANAGER","ผู้จัดการ","bg-blue-100 text-blue-700"), ("CASHIER","แคชเชียร์","bg-green-100 text-green-700"), ("STOCK_KEEPER","คลังสินค้า","bg-amber-100 text-amber-700") })
      {
        <div class="border rounded-xl p-5 hover:border-blue-300">
          <div class="flex items-center gap-3 mb-4">
            <span class="px-3 py-1 rounded-full text-sm font-medium @role.Item3">@role.Item2</span>
            <code class="text-xs text-gray-400">@role.Item1</code>
          </div>
          <ul class="space-y-2 text-sm text-gray-600">
            @if (role.Item1 == "IT_ADMIN") {
              <li class="flex items-center gap-2"><i data-lucide="check" class="w-4 h-4 text-green-500"></i> จัดการทุกส่วนของระบบ</li>
              <li class="flex items-center gap-2"><i data-lucide="check" class="w-4 h-4 text-green-500"></i> เข้าถึงรายงานทั้งหมด</li>
              <li class="flex items-center gap-2"><i data-lucide="check" class="w-4 h-4 text-green-500"></i> จัดการผู้ใช้และสิทธิ์</li>
            } else if (role.Item1 == "MANAGER") {
              <li class="flex items-center gap-2"><i data-lucide="check" class="w-4 h-4 text-green-500"></i> ดูแผงควบคุมและรายงาน</li>
              <li class="flex items-center gap-2"><i data-lucide="check" class="w-4 h-4 text-green-500"></i> จัดการสต็อก</li>
              <li class="flex items-center gap-2"><i data-lucide="x" class="w-4 h-4 text-red-400"></i> ไม่สามารถจัดการผู้ใช้</li>
            } else if (role.Item1 == "CASHIER") {
              <li class="flex items-center gap-2"><i data-lucide="check" class="w-4 h-4 text-green-500"></i> เข้าถึงหน้าจอ POS</li>
              <li class="flex items-center gap-2"><i data-lucide="x" class="w-4 h-4 text-red-400"></i> ไม่เห็นต้นทุน</li>
              <li class="flex items-center gap-2"><i data-lucide="x" class="w-4 h-4 text-red-400"></i> ไม่จัดการสต็อก</li>
            } else {
              <li class="flex items-center gap-2"><i data-lucide="check" class="w-4 h-4 text-green-500"></i> จัดการสต็อกและการรับสินค้า</li>
              <li class="flex items-center gap-2"><i data-lucide="x" class="w-4 h-4 text-red-400"></i> ไม่เข้าถึง POS</li>
            }
          </ul>
        </div>
      }
    </div>
  </div>
</div>
