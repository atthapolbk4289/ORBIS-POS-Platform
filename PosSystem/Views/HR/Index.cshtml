@{ Layout = "_Layout"; }
<div class="space-y-6">
  <div class="flex justify-between items-center">
    <div>
      <h2 class="text-xl font-bold text-gray-800">จัดการฝ่ายบุคคล</h2>
      <p class="text-sm text-gray-500 mt-1">ข้อมูลพนักงาน การเข้างาน และเงินเดือน</p>
    </div>
    <button class="px-4 py-2 rounded-lg text-white text-sm font-medium" style="background:#2D6BE4">
      + เพิ่มพนักงาน
    </button>
  </div>

  <div class="grid grid-cols-4 gap-4">
    <div class="bg-white rounded-xl p-4 shadow-sm text-center">
      <i data-lucide="users" class="w-8 h-8 mx-auto mb-2" style="color:#2D6BE4"></i>
      <p class="text-2xl font-bold text-gray-800">0</p>
      <p class="text-xs text-gray-500 mt-1">พนักงานทั้งหมด</p>
    </div>
    <div class="bg-white rounded-xl p-4 shadow-sm text-center">
      <i data-lucide="user-check" class="w-8 h-8 mx-auto mb-2 text-green-500"></i>
      <p class="text-2xl font-bold text-gray-800">0</p>
      <p class="text-xs text-gray-500 mt-1">เข้างานวันนี้</p>
    </div>
    <div class="bg-white rounded-xl p-4 shadow-sm text-center">
      <i data-lucide="user-x" class="w-8 h-8 mx-auto mb-2 text-red-400"></i>
      <p class="text-2xl font-bold text-gray-800">0</p>
      <p class="text-xs text-gray-500 mt-1">ขาดงาน</p>
    </div>
    <div class="bg-white rounded-xl p-4 shadow-sm text-center">
      <i data-lucide="calendar" class="w-8 h-8 mx-auto mb-2 text-amber-500"></i>
      <p class="text-2xl font-bold text-gray-800">0</p>
      <p class="text-xs text-gray-500 mt-1">ลาพักร้อน</p>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm overflow-hidden">
    <div class="px-5 py-4 border-b flex justify-between items-center">
      <h3 class="font-semibold text-gray-800">รายชื่อพนักงาน</h3>
      <input type="text" placeholder="ค้นหาชื่อพนักงาน..." class="px-3 py-1.5 border rounded-lg text-sm focus:outline-none"/>
    </div>
    <div class="p-12 text-center text-gray-400">
      <i data-lucide="users" class="w-10 h-10 mx-auto mb-2 opacity-30"></i>
      <p>ยังไม่มีข้อมูลพนักงาน</p>
    </div>
  </div>
</div>
