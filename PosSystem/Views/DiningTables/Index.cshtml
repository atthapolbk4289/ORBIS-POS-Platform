@model System.Collections.Generic.List<PosSystem.Controllers.DiningTablesController.TableRow>
@{ Layout = "_Layout"; }

<div class="space-y-6">
    <div class="flex justify-between items-center">
        <div>
            <h2 class="text-xl font-bold text-gray-800">จัดการโต๊ะอาหาร</h2>
            <p class="text-sm text-gray-500 mt-1">กำหนดหมายเลขโต๊ะ โซน และจำนวนที่นั่งสำหรับหน้า POS</p>
        </div>
        <button onclick="document.getElementById('create-table-modal').classList.remove('hidden')" 
                class="px-4 py-2 rounded-lg text-white text-sm font-medium transition-all hover:opacity-90" style="background:#2D6BE4">
            + เพิ่มโต๊ะ
        </button>
    </div>

    @if (TempData["Success"] != null) {
        <div class="rounded-lg bg-green-50 text-green-700 px-4 py-3 text-sm">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null) {
        <div class="rounded-lg bg-red-50 text-red-700 px-4 py-3 text-sm">@TempData["Error"]</div>
    }

    <div class="bg-white rounded-xl shadow-sm overflow-hidden">
        <table class="w-full text-sm">
            <thead style="background:#F8FAFC">
                <tr class="text-left text-xs text-gray-500 uppercase font-semibold">
                    <th class="px-5 py-3">เลขโต๊ะ</th>
                    <th class="px-5 py-3">โซน</th>
                    <th class="px-5 py-3">ความจุ</th>
                    <th class="px-5 py-3">สถานะ</th>
                    <th class="px-5 py-3 text-right">จัดการ</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0) {
                    @foreach (var t in Model) {
                        <tr class="border-t hover:bg-gray-50">
                            <td class="px-5 py-3 font-bold text-blue-700 text-lg">@t.TableNumber</td>
                            <td class="px-5 py-3 text-gray-600">@t.Zone</td>
                            <td class="px-5 py-3 text-gray-600">@t.Capacity ที่นั่ง</td>
                            <td class="px-5 py-3">
                                <span class="px-2 py-1 text-xs rounded-full @(t.Status == "AVAILABLE" ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700")">
                                    @(t.Status == "AVAILABLE" ? "ว่าง" : "ไม่ว่าง")
                                </span>
                            </td>
                            <td class="px-5 py-3 text-right space-x-2">
                                <form asp-action="Delete" method="post" class="inline" onsubmit="return confirm('ยืนยันการลบโต๊ะนี้?')">
                                    <input type="hidden" name="id" value="@t.Id" />
                                    <button type="submit" class="text-gray-400 hover:text-red-500 transition-colors">
                                        <i data-lucide="trash-2" class="w-4 h-4"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                } else {
                    <tr>
                        <td colspan="5" class="px-5 py-12 text-center text-gray-400">
                            <i data-lucide="grid" class="w-10 h-10 mx-auto mb-2 opacity-30"></i>
                            <p>ยังไม่มีข้อมูลโต๊ะอาหาร</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div id="create-table-modal" class="hidden fixed inset-0 bg-black/40 z-50 flex items-center justify-center">
    <div class="bg-white rounded-xl shadow-xl p-6 w-full max-w-md">
        <div class="flex justify-between items-center mb-4">
            <h3 class="text-lg font-bold text-gray-800">เพิ่มโต๊ะใหม่</h3>
            <button onclick="document.getElementById('create-table-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600">✕</button>
        </div>
        <form asp-action="Create" method="post" class="space-y-4">
            <div>
                <label class="block text-xs text-gray-500 mb-1">หมายเลขโต๊ะ (เช่น A1, 01)</label>
                <input name="tableNumber" required class="w-full px-3 py-2 border rounded-lg text-sm outline-none focus:ring-2 focus:ring-blue-500" />
            </div>
            <div>
                <label class="block text-xs text-gray-500 mb-1">โซน (เช่น ห้องแอร์, ระเบียง)</label>
                <input name="zone" class="w-full px-3 py-2 border rounded-lg text-sm outline-none focus:ring-2 focus:ring-blue-500" placeholder="Main" />
            </div>
            <div>
                <label class="block text-xs text-gray-500 mb-1">จำนวนที่นั่ง</label>
                <input name="capacity" type="number" value="4" class="w-full px-3 py-2 border rounded-lg text-sm outline-none" />
            </div>
            <div class="flex justify-end gap-2 pt-2">
                <button type="button" onclick="document.getElementById('create-table-modal').classList.add('hidden')" class="px-4 py-2 text-sm text-gray-600 hover:bg-gray-100 rounded-lg transition-all">ยกเลิก</button>
                <button type="submit" class="px-4 py-2 text-sm text-white rounded-lg font-medium transition-all" style="background:#2D6BE4">บันทึกข้อมูล</button>
            </div>
        </form>
    </div>
</div>
