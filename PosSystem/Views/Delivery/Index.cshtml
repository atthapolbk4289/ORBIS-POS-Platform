@{ Layout = "_Layout"; }
<div class="space-y-6">
  <!-- Header -->
  <div class="flex justify-between items-center">
    <div>
      <h2 class="text-xl font-bold text-gray-800">ขนส่งสินค้า</h2>
      <p class="text-sm text-gray-500 mt-1">ติดตามและจัดการการขนส่งสินค้าทั้งหมด</p>
    </div>
    <button class="px-4 py-2 rounded-lg text-white text-sm font-medium" style="background:#2D6BE4">
      + สร้างรายการขนส่ง
    </button>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-4 gap-4">
    <div class="bg-white rounded-xl p-4 shadow-sm border-l-4 border-blue-500">
      <p class="text-xs text-gray-500">รอดำเนินการ</p>
      <p class="text-2xl font-bold text-blue-600 mt-1">0</p>
    </div>
    <div class="bg-white rounded-xl p-4 shadow-sm border-l-4 border-amber-400">
      <p class="text-xs text-gray-500">กำลังขนส่ง</p>
      <p class="text-2xl font-bold text-amber-600 mt-1">0</p>
    </div>
    <div class="bg-white rounded-xl p-4 shadow-sm border-l-4 border-green-500">
      <p class="text-xs text-gray-500">ส่งสำเร็จ</p>
      <p class="text-2xl font-bold text-green-600 mt-1">0</p>
    </div>
    <div class="bg-white rounded-xl p-4 shadow-sm border-l-4 border-red-400">
      <p class="text-xs text-gray-500">มีปัญหา</p>
      <p class="text-2xl font-bold text-red-600 mt-1">0</p>
    </div>
  </div>

  <!-- Table -->
  <div class="bg-white rounded-xl shadow-sm overflow-hidden">
    <div class="px-5 py-4 border-b flex justify-between items-center">
      <h3 class="font-semibold text-gray-800">รายการขนส่งทั้งหมด</h3>
      <input type="text" placeholder="ค้นหา..." class="px-3 py-1.5 border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"/>
    </div>
    <table class="w-full text-sm">
      <thead style="background:#F8FAFC">
        <tr class="text-left text-xs text-gray-500 uppercase">
          <th class="px-5 py-3">เลขที่</th>
          <th class="px-5 py-3">ปลายทาง</th>
          <th class="px-5 py-3">ผู้ขนส่ง</th>
          <th class="px-5 py-3">วันที่ส่ง</th>
          <th class="px-5 py-3">สถานะ</th>
          <th class="px-5 py-3">จัดการ</th>
        </tr>
      </thead>
      <tbody>
        <tr><td colspan="6" class="px-5 py-12 text-center text-gray-400">
          <i data-lucide="truck" class="w-10 h-10 mx-auto mb-2 opacity-30"></i>
          <p>ยังไม่มีรายการขนส่ง</p>
        </td></tr>
      </tbody>
    </table>
  </div>
</div>
