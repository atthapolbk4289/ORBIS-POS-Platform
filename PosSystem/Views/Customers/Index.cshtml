@using PosSystem.Controllers
@model System.Collections.Generic.List<CustomersController.CustomerRow>
@{ Layout = "_Layout"; }
<div class="space-y-6">
  @{
    var openCreate = (ViewData["OpenCreate"] as bool?) == true;
  }
  @if (TempData["Success"] != null)
  {
    <div class="rounded-lg bg-green-50 text-green-700 px-4 py-3 text-sm">@TempData["Success"]</div>
  }
  @if (TempData["Error"] != null)
  {
    <div class="rounded-lg bg-red-50 text-red-700 px-4 py-3 text-sm">@TempData["Error"]</div>
  }
  <div class="flex justify-between items-center">
    <div>
      <h2 class="text-xl font-bold text-gray-800">ลูกค้า</h2>
      <p class="text-sm text-gray-500 mt-1">จัดการข้อมูลลูกค้าและสมาชิก</p>
    </div>
    <a asp-action="Index" asp-route-openCreate="true" class="px-4 py-2 rounded-lg text-white text-sm font-medium inline-block" style="background:#2D6BE4">+ เพิ่มลูกค้า</a>
  </div>

  <form method="get" class="bg-white rounded-xl p-4 shadow-sm flex gap-3">
    <input name="search" value="@ViewData["Search"]" placeholder="ค้นหาชื่อ หรือเบอร์โทร..." 
           class="flex-1 px-3 py-2 border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"/>
    <button type="submit" class="px-4 py-2 rounded-lg text-white text-sm" style="background:#2D6BE4">ค้นหา</button>
  </form>

  <div class="bg-white rounded-xl shadow-sm overflow-hidden">
    <table class="w-full text-sm">
      <thead style="background:#F8FAFC">
        <tr class="text-left text-xs text-gray-500 uppercase">
          <th class="px-5 py-3">ชื่อลูกค้า</th>
          <th class="px-5 py-3">เบอร์โทร</th>
          <th class="px-5 py-3">อีเมล</th>
          <th class="px-5 py-3">ระดับ</th>
          <th class="px-5 py-3 text-right">แต้มสะสม</th>
          <th class="px-5 py-3 text-right">ยอดซื้อสะสม</th>
          <th class="px-5 py-3">สถานะ</th>
          <th class="px-5 py-3">สมาชิกตั้งแต่</th>
          <th class="px-5 py-3 text-right">จัดการ</th>
        </tr>
      </thead>
      <tbody>
        @if (Model != null && Model.Count > 0)
        {
          @foreach (var c in Model)
          {
            <tr class="border-t hover:bg-gray-50">
              <td class="px-5 py-3 font-medium text-gray-800">@c.Name</td>
              <td class="px-5 py-3 text-gray-600">@(c.Phone ?? "-")</td>
              <td class="px-5 py-3 text-gray-500 text-xs">@(c.Email ?? "-")</td>
              <td class="px-5 py-3">
                @if (!string.IsNullOrEmpty(c.MemberLevel))
                {
                  <span class="px-2 py-1 text-xs rounded-full bg-amber-100 text-amber-700">@c.MemberLevel</span>
                }
              </td>
              <td class="px-5 py-3 text-right font-semibold text-amber-600">@c.Points.ToString("N0")</td>
              <td class="px-5 py-3 text-right">฿@c.TotalSpent.ToString("N2")</td>
              <td class="px-5 py-3">
                <span class="px-2 py-1 text-xs rounded-full @(c.IsActive ? "bg-green-100 text-green-700" : "bg-gray-100 text-gray-500")">
                  @(c.IsActive ? "ใช้งาน" : "ระงับ")
                </span>
              </td>
              <td class="px-5 py-3 text-gray-500 text-xs">@c.CreatedAt.ToString("dd/MM/yyyy")</td>
              <td class="px-5 py-3 text-right">
                <form asp-action="Delete" method="post" class="inline" onsubmit="return confirm('ระงับการใช้งานลูกค้ารายนี้?')">
                  <input type="hidden" name="id" value="@c.Id" />
                  <button type="submit" class="p-1.5 text-gray-400 hover:text-red-500 transition-colors">
                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                  </button>
                </form>
              </td>
            </tr>
          }
        }
        else
        {
          <tr><td colspan="8" class="px-5 py-12 text-center text-gray-400">
            <i data-lucide="user-check" class="w-10 h-10 mx-auto mb-2 opacity-30"></i>
            <p>ยังไม่มีข้อมูลลูกค้า</p>
          </td></tr>
        }
      </tbody>
    </table>
  </div>
</div>

<div id="create-customer-modal" class="@(openCreate ? "" : "hidden") fixed inset-0 bg-black/40 z-40 items-center justify-center">
  <div class="max-w-lg w-full bg-white rounded-xl shadow-xl p-5 mx-4 mt-16">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-semibold text-gray-800">เพิ่มลูกค้าใหม่</h3>
      <a asp-action="Index" class="text-gray-400">✕</a>
    </div>
    <form method="post" asp-action="Create" class="space-y-3">
      <input name="Name" required placeholder="ชื่อลูกค้า" class="w-full px-3 py-2 border rounded-lg text-sm" />
      <input name="Phone" required placeholder="เบอร์โทร" class="w-full px-3 py-2 border rounded-lg text-sm" />
      <input name="Email" placeholder="อีเมล (ถ้ามี)" class="w-full px-3 py-2 border rounded-lg text-sm" />
      <select name="MemberLevel" class="w-full px-3 py-2 border rounded-lg text-sm">
        <option value="NORMAL">NORMAL</option>
        <option value="SILVER">SILVER</option>
        <option value="GOLD">GOLD</option>
        <option value="PLATINUM">PLATINUM</option>
      </select>
      <label class="flex items-center gap-2 text-sm text-gray-700">
        <input type="checkbox" name="IsActive" checked value="true" />
        เปิดใช้งานลูกค้าทันที
      </label>
      <div class="flex justify-end gap-2 pt-2">
        <a asp-action="Index" class="px-4 py-2 border rounded-lg text-sm inline-block">ยกเลิก</a>
        <button type="submit" class="px-4 py-2 rounded-lg text-white text-sm" style="background:#2D6BE4">บันทึก</button>
      </div>
    </form>
  </div>
</div>
